{
  "name": "datacontract-editor",
  "version": "0.1.10",
  "description": "A visual editor for data contracts using the Open Data Contract Standard (ODCS)",
  "repository": {
    "type": "git",
    "url": "https://github.com/datacontract/datacontract-editor"
  },
  "type": "module",
  "bin": {
    "datacontract-editor": "./bin/datacontract-editor.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "dev:custom": "vite --mode custom",
    "build": "vite build --mode production",
    "build:debug": "vite build --mode debug",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "start": "npm run build && node bin/datacontract-editor.js",
    "start:debug": "npm run build:debug && node bin/datacontract-editor.js"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "dompurify": "^3.4.8"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.10",
    "@monaco-editor/react": "^4.7.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.20",
    "@xyflow/react": "^12.11.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "dagre": "^0.8.5",
    "easymde": "^2.21.0",
    "monaco-editor": "^0.54.0",
    "monaco-yaml": "^5.5.1",
    "open": "^10.2.0",
    "path-browserify": "^1.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "baseline-browser-mapping": "^2.10.35",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "tailwindcss": "^4.1.17",
    "vite": "^7.3.5"
  }
}
